# 이 파일을 복사해서 .env 를 만든 뒤, 각자 발급받은 키를 채워 넣으세요.
#   cp .env.example .env
#
# .env 는 .gitignore 에 등록되어 있어 커밋되지 않습니다.
# 키를 코드나 문서에 직접 적지 마세요. 실수로 커밋했다면 즉시 재발급해야 합니다.

# ODsay LAB (https://lab.odsay.com) — 대중교통 도달권(isochrone) 조회
# 마이페이지 > API 키 관리에서 발급. 무료 요금제는 초당 호출 제한이 있습니다.
ODSAY_API_KEY=<발급받은_키를_여기에>

# TMAP (https://openapi.sk.com) — POI 검색, 지오코딩, 대중교통 경로
# 프로젝트를 만든 뒤 앱 키(appKey)를 발급받습니다.
TMAP_APP_KEY=<발급받은_키를_여기에>

# Kakao Developers (https://developers.kakao.com) — Kakao Local 장소 검색
# 내 애플리케이션 > 앱 키 > REST API 키 (JavaScript 키가 아닙니다)
KAKAO_REST_KEY=<발급받은_키를_여기에>
